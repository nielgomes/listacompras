# ============================================
# Variáveis de Ambiente - Lista Compras
# ============================================
# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env
#
# AVISO: O arquivo .env deve estar no .gitignore!
# ============================================

# ============================================
# Firebase Configuration (Recomendado)
# ============================================
# Obtenha estas credenciais no Console do Firebase
# https://console.firebase.google.com/

# ID do projeto no Firebase (ex: lista-compras-app)
FIREBASE_PROJECT_ID=lista-compras-app

# Chave da API Web (Firebase > Configurações do Projeto > Geral > Seus apps)
FIREBASE_API_KEY=AIzaXXXXXXXXXXX

# Domínio de autenticação (ex: lista-compras-app.firebaseapp.com)
FIREBASE_AUTH_DOMAIN=lista-compras-app-XXXXXXXXXXXX.firebaseapp.com

# Bucket de armazenamento (ex: lista-compras-app.appspot.com)
FIREBASE_STORAGE_BUCKET=lista-compras-app-XXXXXXXXX.firebasestorage.app

# Sender ID para Messaging (obtenha no Firebase Console)
FIREBASE_MESSAGING_SENDER_ID=1234567890987

# App ID do Firebase (obtenha no Firebase Console)
# Formato: 1:123456789012:android:abcdef123456
FIREBASE_APP_ID=1:12345678:web:XXXXXXXXXXXXXXXXXXX

# Openrouter.ai
OPENROUTER_API_KEY=sk-or
OPENROUTER_MODEL1=openai/gpt-oss-120b:free
OPENROUTER_MODEL2=google/gemma-4-26b-a4b-it:free
OPENROUTER_MODEL3=deepseek/deepseek-v4-flash


# ============================================
# Configurações de Ambiente
# ============================================
# Ambiente: development | production
ENVIRONMENT=development

# Debug mode
DEBUG=true